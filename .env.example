# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=altarFunds
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Firebase
# Path to service-account JSON downloaded from:
# Firebase console → Project Settings → Service Accounts → Generate new private key
# NEVER commit the actual file — keep it outside the repo or in a secrets manager
FIREBASE_CREDENTIALS_PATH=service-account.json
FIREBASE_PROJECT_ID=sanctum-cf7e7

# Platform fee deducted before disbursing to churches (percentage, e.g. 1.5 = 1.5%)
PLATFORM_FEE_PERCENTAGE=1.5

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MPESA
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=your-mpesa-shortcode
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback/
