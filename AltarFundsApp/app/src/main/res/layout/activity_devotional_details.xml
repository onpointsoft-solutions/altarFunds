<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg">

    <!-- ── Toolbar ─────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cream_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_toolbar_icon"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/gold_primary"
                android:contentDescription="Back" />

            <!-- Centered title -->
            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Daily Devotional"
                android:textColor="@color/ink_muted"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium" />

            <!-- More button -->
            <ImageView
                android:id="@+id/btnMore"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end"
                android:background="@drawable/bg_toolbar_icon"
                android:padding="10dp"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/gold_primary"
                android:contentDescription="More options" />

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable body ─────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cream_bg"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="40dp">

            <!-- ── Banner card ───────────────────────────────────────── -->
            <!--
                bg_banner_cross drawable:
                  layer-list with:
                    item 1: gradient #2C2015 → #6B4E2A (135°)
                    item 2: centered cross shape at 15% opacity (white)
                Alternatively use a real photo with a dark gradient overlay.
            -->
            <androidx.cardview.widget.CardView
                android:id="@+id/bannerCard"
                android:layout_width="0dp"
                android:layout_height="240dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Dark warm background image / gradient -->
                    <ImageView
                        android:id="@+id/ivBanner"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_banner_cross"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Bottom gradient scrim -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@drawable/gradient_overlay_bottom"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- "Today" badge pill -->
                    <TextView
                        android:id="@+id/tvBannerBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_gold_pill"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="TODAY"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:letterSpacing="0.10"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Devotional title on banner -->
                    <TextView
                        android:id="@+id/tvBannerTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="6dp"
                        android:text="Walking in the Light of Grace"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.2"
                        app:layout_constraintBottom_toTopOf="@id/tvBannerSubtitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Author on banner -->
                    <TextView
                        android:id="@+id/tvBannerSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="18dp"
                        android:text="By Pastor James Odhiambo"
                        android:textColor="#A6FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.03"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Meta row (date · read time) ──────────────────────── -->
            <LinearLayout
                android:id="@+id/llMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bannerCard">

                <!-- Gold dot -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_gold_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="March 30, 2026"
                    android:textColor="@color/ink_muted"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_gold_dot"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvReadTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 min read"
                    android:textColor="@color/ink_muted"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <!-- ── Main title ────────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Walking in the\nLight of Grace"
                android:textColor="@color/ink_primary"
                android:textSize="28sp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="1.2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llMeta" />

            <!-- ── Scripture card (white + gold left border) ─────────── -->
            <!--
                bg_scripture_card: layer-list
                  item 1: shape with white fill, 1dp stroke #EAD9C0, corners 16dp
                  item 2: shape with gold fill (#B8935A), width 3dp, pinned to left
                          (use inset with right="0dp" trick or a custom drawable)
            -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardScripture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Gold left accent bar -->
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/gold_primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SCRIPTURE REFERENCE"
                            android:textColor="@color/gold_primary"
                            android:textSize="10sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tvScripture"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John 3:16 — For God so loved the world…"
                            android:textColor="@color/ink_primary"
                            android:textSize="18sp"
                            android:fontFamily="serif"
                            android:textStyle="italic" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Content card ──────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardScripture">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVOTIONAL"
                        android:textColor="@color/ink_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Devotional content goes here…"
                        android:textColor="@color/ink_soft"
                        android:textSize="17sp"
                        android:fontFamily="serif"
                        android:lineSpacingMultiplier="1.75" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Reactions & Actions card ──────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardReactions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardContent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Total reactions count -->
                    <TextView
                        android:id="@+id/tvReactionCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 reactions"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <!-- Emoji reaction chips for adding reactions -->
                    <LinearLayout
                        android:id="@+id/llEmojiReactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tvAddReaction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="React:"
                            android:textColor="@color/ink_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupReactions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="false"
                            app:chipSpacingHorizontal="4dp">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipLove"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❤️"
                                android:textSize="18sp"
                                app:chipBackgroundColor="@color/chip_unselected"
                                app:chipStrokeWidth="1dp"
                                app:chipStrokeColor="@color/card_border"
                                app:chipMinHeight="36dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPray"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🙏"
                                android:textSize="18sp"
                                app:chipBackgroundColor="@color/chip_unselected"
                                app:chipStrokeWidth="1dp"
                                app:chipStrokeColor="@color/card_border"
                                app:chipMinHeight="36dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipThumbsUp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👍"
                                android:textSize="18sp"
                                app:chipBackgroundColor="@color/chip_unselected"
                                app:chipStrokeWidth="1dp"
                                app:chipStrokeColor="@color/card_border"
                                app:chipMinHeight="36dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipFire"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥"
                                android:textSize="18sp"
                                app:chipBackgroundColor="@color/chip_unselected"
                                app:chipStrokeWidth="1dp"
                                app:chipStrokeColor="@color/card_border"
                                app:chipMinHeight="36dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipCelebrate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎉"
                                android:textSize="18sp"
                                app:chipBackgroundColor="@color/chip_unselected"
                                app:chipStrokeWidth="1dp"
                                app:chipStrokeColor="@color/card_border"
                                app:chipMinHeight="36dp" />

                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>

                    <!-- Existing reactions display -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvReactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                    <!-- Thin divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/card_border"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp" />

                    <!-- Action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Like -->
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:id="@+id/btnLikeBg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_reaction_button_selector"
                                android:contentDescription="Like Background" />

                            <ImageView
                                android:id="@+id/btnLike"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_heart_outline"
                                app:tint="@color/gold_primary"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="2dp"
                                android:contentDescription="Like" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLikeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="16dp"
                            android:text="124"
                            android:textColor="@color/ink_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif" />

                        <!-- Comment -->
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:id="@+id/btnCommentBg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_reaction_button_selector"
                                android:contentDescription="Comment Background" />

                            <ImageView
                                android:id="@+id/btnComment"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_comment"
                                app:tint="@color/gold_primary"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="2dp"
                                android:contentDescription="Comment" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvCommentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="18"
                            android:textColor="@color/ink_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif" />

                        <!-- Spacer pushes bookmark + share to end -->
                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Bookmark -->
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:id="@+id/btnBookmarkBg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_reaction_button_selector"
                                android:contentDescription="Bookmark Background" />

                            <ImageView
                                android:id="@+id/btnBookmark"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bookmark_outline"
                                app:tint="@color/gold_primary"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="2dp"
                                android:contentDescription="Bookmark" />

                        </FrameLayout>

                        <!-- Share -->
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp">

                            <ImageView
                                android:id="@+id/btnShareBg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_reaction_button_selector"
                                android:contentDescription="Share Background" />

                            <ImageView
                                android:id="@+id/btnShare"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_share"
                                app:tint="@color/gold_primary"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="2dp"
                                android:contentDescription="Share" />

                        </FrameLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Comments card ─────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardComments"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardReactions">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvCommentsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="COMMENTS"
                        android:textColor="@color/ink_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Comment input pill -->
                    <LinearLayout
                        android:id="@+id/llCommentInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_comment_input"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <EditText
                            android:id="@+id/etComment"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Add a comment…"
                            android:inputType="textCapSentences|textMultiLine"
                            android:maxLines="3"
                            android:textColor="@color/ink_primary"
                            android:textColorHint="@color/ink_muted"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif" />

                        <ImageButton
                            android:id="@+id/btnSendComment"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_send_button"
                            android:padding="8dp"
                            android:src="@drawable/ic_send"
                            app:tint="@android:color/white"
                            android:contentDescription="Send comment" />

                    </LinearLayout>

                    <!-- Comment list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvComments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/tvNoComments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:text="No comments yet. Be the first!"
                        android:textColor="@color/ink_muted"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Loading spinner (centered over everything) -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/gold_primary"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
