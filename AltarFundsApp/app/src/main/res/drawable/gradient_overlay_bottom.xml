<?xml version="1.0" encoding="utf-8"?>
<!--
  Dark gradient overlay — transparent at the top, 70 % black at the bottom.
  Used on devotional banner images so the author text is always legible.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:angle="270"
        android:startColor="#00000000"
        android:centerColor="#33000000"
        android:endColor="#B3000000"
        android:type="linear" />
</shape>
